# ============================================
# Bags Signal - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env files with real API keys!

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Endpoints
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws

# Privy Wallet Authentication
# Get your app ID from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Bags.fm API (Server-side only)
# Get your API key from https://dev.bags.fm
BAGS_API_BASE_URL=https://api.bags.fm/v1
BAGS_API_KEY=your_bags_api_key_here

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Bags.fm API
BAGS_API_BASE_URL=https://api.bags.fm/v1
BAGS_API_KEY=your_bags_api_key_here

# Helius RPC (Solana)
# Get your API key from https://helius.dev
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
HELIUS_API_KEY=your_helius_api_key_here

# Birdeye API (Price & Volume Data)
# Get your API key from https://birdeye.so
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# PostgreSQL (Optional - for persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/bags_signal

# Python AI Service
AI_SERVICE_URL=http://localhost:8000

# ============================================
# PYTHON AI SERVICE CONFIGURATION
# ============================================

PORT=8000
ENVIRONMENT=development
MODEL_VERSION=1.0.0-ml

# ============================================
# PRODUCTION DEPLOYMENT
# ============================================

# For production deployment:
# 1. Set NODE_ENV=production
# 2. Use HTTPS URLs for all endpoints
# 3. Set up proper CORS configuration
# 4. Enable Redis for caching
# 5. Set up PostgreSQL for data persistence
# 6. Use environment-specific API keys
# 7. Enable rate limiting
# 8. Set up monitoring and logging

# Example Production URLs:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com/ws
# BAGS_API_BASE_URL=https://api.bags.fm/v1
# AI_SERVICE_URL=https://ai.yourdomain.com
